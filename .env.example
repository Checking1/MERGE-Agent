# AAT-Agent Environment Configuration Template
# Copy this file to .env and fill in actual values

# ================================
# DeepSeek API Configuration
# ================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.8
DEEPSEEK_MAX_TOKENS=500

# ================================
# Neo4j Database Configuration
# ================================
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DB=neo4j

# ================================
# Dataset Paths (Optional)
# ================================
# If not set, will auto-detect from data/interim directory
AAT_INTRO_EVENT_PATH=/path/to/intro_event_dataset.csv
AAT_GROUP_EVENT_PATH=/path/to/group_event_dataset.csv
AAT_BREED_EVENT_PATH=/path/to/breed_event_dataset.csv
AAT_DELIVERY_EVENT_PATH=/path/to/delivery_event_dataset.csv
AAT_NORMAL_IMMU_EVENT_PATH=/path/to/normal_immu_event_dataset.csv
AAT_ABORT_EVENT_PATH=/path/to/abort_event_dataset.csv
AAT_RISK_EVENT_PATH=/path/to/risk_event_dataset.csv
AAT_SECURITY_EVENT_PATH=/path/to/security_event_dataset.csv

# ================================
# Task Parameters (Optional)
# ================================
AAT_FARM_ID=DEMO_FARM
AAT_REFERENCE_DATE=2025-01-01
